<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Classic Bluetooth (Android ≤ 11) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- BLE scanning requires location on Android 6–11 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />

    <!-- Bluetooth (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- neverForLocation: we scan for a device by name, not for the user's location -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />

    <!-- Hardware features -->
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
    <!-- required="false" so sideloading works on non-BLE devices; app checks at runtime -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- External storage write — needed only on API 24-28 for saving EEPROM dumps -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.NicFwChannelEditor">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NicFwChannelEditor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ChannelEditActivity"
            android:exported="false"
            android:theme="@style/Theme.NicFwChannelEditor" />
        <activity
            android:name=".GroupLabelEditActivity"
            android:exported="false"
            android:theme="@style/Theme.NicFwChannelEditor" />
        <activity
            android:name=".ChirpImportActivity"
            android:exported="false"
            android:theme="@style/Theme.NicFwChannelEditor" />
        <activity
            android:name=".ChannelSortActivity"
            android:exported="false"
            android:theme="@style/Theme.NicFwChannelEditor" />
        <activity
            android:name=".BandPlanEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.NicFwChannelEditor" />
        <activity
            android:name=".BandPlanEntryEditActivity"
            android:exported="false"
            android:theme="@style/Theme.NicFwChannelEditor" />

        <!-- FileProvider for sharing EEPROM dump files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
    </application>
</manifest>
